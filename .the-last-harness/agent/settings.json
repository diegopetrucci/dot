{
  "packages": [
    "git:github.com/diegopetrucci/the-last-harness@main",
    "npm:@diegopetrucci/pi-openai-fast@0.1.6",
    "npm:@gotgenes/pi-anthropic-auth@1.0.0",
    "npm:@ff-labs/pi-fff@0.9.6",
    "npm:@diegopetrucci/pi-inline-bash@0.1.3",
    "npm:@diegopetrucci/pi-notify@0.1.7",
    "npm:@diegopetrucci/pi-context-inspector@0.1.4",
    "npm:@diegopetrucci/pi-dirty-repo-guard@0.1.4",
    "npm:@diegopetrucci/pi-brrr",
    "npm:@diegopetrucci/pi-mcp-adapter@2.10.1",
    "npm:@diegopetrucci/pi-intercom@0.7.0",
    "npm:@diegopetrucci/pi-web-access@0.10.10",
    "npm:@diegopetrucci/pi-quiet-tools@0.1.4",
    "npm:@diegopetrucci/pi-subagents@0.31.4"
  ],
  "theme": "the-last-harness",
  "editorPaddingX": 1,
  "quietStartup": true,
  "collapseChangelog": true,
  "lastChangelogVersion": "9999.0.0",
  "subagents": {
    "agentDirs": [
      "tlh/agents/subagents"
    ],
    "disableBuiltins": true
  },
  "warnings": {
    "anthropicExtraUsage": false
  },
  "tlh": {
    "tickets": {
      "enabled": true,
      "installPath": "/opt/homebrew/bin/tk"
    },
    "defaultExtensionProvenance": {
      "managedPackageIdentities": [
        "npm:@diegopetrucci/pi-context-inspector",
        "npm:@diegopetrucci/pi-dirty-repo-guard",
        "npm:@diegopetrucci/pi-inline-bash",
        "npm:@diegopetrucci/pi-intercom",
        "npm:@diegopetrucci/pi-mcp-adapter",
        "npm:@diegopetrucci/pi-notify",
        "npm:@diegopetrucci/pi-openai-fast",
        "npm:@diegopetrucci/pi-quiet-tools",
        "npm:@diegopetrucci/pi-subagents",
        "npm:@diegopetrucci/pi-web-access",
        "npm:@ff-labs/pi-fff",
        "npm:@gotgenes/pi-anthropic-auth"
      ]
    },
    "experimental": {
      "enabledFeatures": [
        "contrarian",
        "ticket-workflow-ui"
      ]
    },
    "primaryAgent": {
      "modelOverrides": {
        "architect": "openai-codex/gpt-5.6-sol"
      }
    }
  },
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.6-sol",
  "defaultThinkingLevel": "medium"
}