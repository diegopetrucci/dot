# Keybinds
keybind = global:cmd+ctrl+z=toggle_quick_terminal
keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:bottom
keybind = ctrl+k=goto_split:top
keybind = ctrl+l=goto_split:right
keybind = ctrl+a>h=new_split:left
keybind = ctrl+a>j=new_split:down
keybind = ctrl+a>k=new_split:up
keybind = ctrl+a>l=new_split:right
keybind = super+r=reload_config
keybind = ctrl+shift+i=prompt_surface_title
# keybind = shift+enter=text:\n
# keybind = ctrl+a>f=toggle_split_zoom

# Mouse & Scroll
mouse-hide-while-typing = true
scrollback-limit = 1000000

# Notifications
notify-on-command-finish = always
notify-on-command-finish-action = bell,notify
bell-features = attention,title

# Session
window-save-state = always
window-inherit-working-directory = false
tab-inherit-working-directory = false
split-inherit-working-directory = true

# Theming
background-opacity = 0.96
background-blur-radius = 40
font-size = 18
macos-titlebar-style = tabs
macos-titlebar-proxy-icon = hidden
theme = catppuccin-mocha.conf
window-width = 105
window-height = 30
#window-padding-y = 0
